          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e03" value="3 init_namespace(context)" style="endArrow=block;html=1;rounded=0;strokeColor=#666666;" edge="1" parent="1" source="pipeline" target="dataplane">
